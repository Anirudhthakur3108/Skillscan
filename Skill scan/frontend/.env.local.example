# Frontend Environment Configuration
# Copy this to .env.local and fill in your values

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=SkillScan

# Feature Flags
VITE_ENABLE_RESUME_UPLOAD=true
VITE_ENABLE_SKILL_INPUT=true
VITE_ENABLE_ASSESSMENTS=true
VITE_ENABLE_LEARNING_PLANS=true
VITE_ENABLE_DASHBOARD=true
